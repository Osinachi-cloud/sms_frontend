# ===================================================================
# SchoolSaaS Frontend — Environment Variables
# ===================================================================
# Copy this file to .env.local for local development.
# For Vercel, set these in the Vercel Dashboard → Project Settings → Environment Variables.
# ===================================================================

# -------------------------------------------------------------------
# API Base URL
# -------------------------------------------------------------------
# Local development:
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api
# Production (your Railway backend domain):
# NEXT_PUBLIC_API_BASE_URL=https://schoolsaas-api.up.railway.app/api

# Server-side API base (used by API rewrites in next.config.mjs)
API_BASE_URL=http://localhost:8080

# -------------------------------------------------------------------
# Feature Flags
# -------------------------------------------------------------------
NEXT_PUBLIC_USE_MOCK_FALLBACK=false
NEXT_PUBLIC_ENABLE_AI_TUTOR=true
NEXT_PUBLIC_ENABLE_OFFLINE_MODE=true

# -------------------------------------------------------------------
# Optional: Analytics / Error Tracking
# -------------------------------------------------------------------
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_SENTRY_DSN=
