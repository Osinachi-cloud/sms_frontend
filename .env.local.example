# ===================================================================
# SchoolSaaS Frontend — Environment Variables
# ===================================================================
# Copy this file to .env.local for local development.
# For Vercel, set these in the Vercel Dashboard → Project Settings → Environment Variables.
# ===================================================================

# -------------------------------------------------------------------
# Backend API Base URL
# -------------------------------------------------------------------
# This is used for:
#  - Client-side Axios calls (api.ts)
#  - Server-side API rewrites (next.config.mjs)
#
# Local development:
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Production (your Railway / Render / VPS backend domain):
# NEXT_PUBLIC_API_BASE_URL=https://schoolsaas-api.up.railway.app

# -------------------------------------------------------------------
# Feature Flags
# -------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_AI_TUTOR=true

# -------------------------------------------------------------------
# Optional: Analytics / Error Tracking
# -------------------------------------------------------------------
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_SENTRY_DSN=
